# Redis
REDIS_URL=redis://redis:6379/0
# Optional: set a password to enable Redis authentication.
# When set, compose.yml will pass --requirepass to the Redis server
# and include the password in REDIS_URL for all services.
# REDIS_PASSWORD=
# Defensive memory cap for the Redis server (-> `redis-server --maxmemory`).
# Default 0 = unlimited (current behaviour). Set e.g. 2gb on a busy box so a
# pathological backlog fails writes loudly (OOM) instead of eating all host
# RAM. The eviction policy is hardcoded to noeviction in compose and is NOT
# configurable: RQ generation counters / sub-job sets / pipeline context must
# never be evicted or the DAG corrupts.
# REDIS_MAXMEMORY=0

# Storage (paths inside container)
DATABASE_PATH=/app/data/db/whisper_ui.db
UPLOAD_DIR=/app/data/uploads
OUTPUT_DIR=/app/data/outputs

# Upload / media limits
# MAX_UPLOAD_SIZE: per-file upload cap in bytes (default 2 GiB). Enforce a
# matching client_max_body_size at any reverse proxy in front of the app so
# oversized bodies are rejected before they reach the worker.
# MAX_UPLOAD_SIZE=2147483648
# YOUTUBE_MAX_DURATION: reject YouTube sources longer than this many seconds
# (default 14400 = 4h).
# YOUTUBE_MAX_DURATION=14400
# TWITTER_MAX_DURATION: reject X posts whose attached video is longer than this
# many seconds (default 14400 = 4h).
# TWITTER_MAX_DURATION=14400
# TWITTER_COOKIES_FILE: container path to a Netscape cookies.txt exported from a
# logged-in X session; enables fetching login-walled / age-restricted posts.
# Leave unset for anonymous downloads of public posts. No secret is stored in
# code or the database. Enabling needs BOTH steps (the env var alone is not
# enough — the file must also be mounted into the download worker):
#   1. Set the container path here, e.g.
#        TWITTER_COOKIES_FILE=/secrets/twitter_cookies.txt
#   2. Mount the host file read-only into each download worker (worker-gpu /
#      worker-cpu / worker-rocm / worker-io) and make it readable by the worker
#      user uid 1000 (e.g. `chmod 644 twitter_cookies.txt`). Use a
#      compose.override.yml so upgrades do not clobber it:
#        services:
#          worker-io:
#            volumes:
#              - ./twitter_cookies.txt:/secrets/twitter_cookies.txt:ro
# TWITTER_COOKIES_FILE=/secrets/twitter_cookies.txt

# Whisper
# WHISPER_MODEL: default model shown in UI dropdown.
# GPU deployment: large-v3 (default if unset)
# CPU deployment: base (recommended, set explicitly)
# WHISPER_MODEL=large-v3
COMPUTE_TYPE=int8_float16
DEVICE=cuda
# BATCH_SIZE: use 4 as default, reduce to 2 for 8GB VRAM GPUs, increase to 8+ for 16GB+ VRAM
BATCH_SIZE=4

# Transcription backend
# TRANSCRIBE_BACKEND: "whisperx" (faster-whisper / CTranslate2, CUDA + CPU;
# default) or "whispercpp" (whisper.cpp HIP CLI). The rocm compose profile
# sets this to whispercpp automatically because CTranslate2 has no ROCm backend.
# TRANSCRIBE_BACKEND=whisperx
# WHISPERCPP_BINARY: whisper.cpp CLI binary name or path inside the worker
# image. Only needed when baking a custom build into the image.
# WHISPERCPP_BINARY=whisper-cli
# WHISPERCPP_THREADS: CPU threads for whisper.cpp (0 = its own default).
# WHISPERCPP_THREADS=0
# WHISPERCPP_VAD: Silero VAD pre-segmentation for whisper.cpp. Keep enabled —
# without it, long silence/music makes the decoder hallucinate in a loop.
# WHISPERCPP_VAD=true
# WHISPERCPP_VAD_MODEL: GGML VAD model file (fetched from the ggml-org/whisper-vad
# HF repo, or pre-baked next to the GGML model for offline use).
# WHISPERCPP_VAD_MODEL=ggml-silero-v5.1.2.bin
# WHISPERCPP_MAX_CONTEXT: text-context tokens carried across 30s decode windows.
# 0 (default) stops hallucination loops from propagating; -1 = whisper.cpp default.
# WHISPERCPP_MAX_CONTEXT=0

# AMD GPU / ROCm (docker compose --profile rocm)
# The rocm worker forces DEVICE=rocm + TRANSCRIBE_BACKEND=whispercpp itself.
# AMDGPU_TARGETS: GPU arch whisper.cpp is compiled for (gfx1151 = Strix Halo).
# AMDGPU_TARGETS=gfx1151
# VIDEO_GID / RENDER_GID: host group IDs for /dev/dri passthrough. Find them
# with `getent group video render`. Defaults (44 / 993) suit a Strix Halo box.
# VIDEO_GID=44
# RENDER_GID=993
# WORKER_GPU_QUEUES / WORKER_CPU_QUEUES / WORKER_ROCM_QUEUES / WORKER_IO_QUEUES /
# WORKER_LLM_QUEUES: queues each worker listens on. The gpu/cpu/rocm defaults
# include every queue (incl. whisper:llm) so a single worker still runs the
# whole pipeline; worker-io defaults to the io/cpu/llm queues and worker-llm
# to whisper:llm only — see the scaled-topology examples below and in README.
# WORKER_GPU_QUEUES=whisper:gpu whisper:io whisper:cpu whisper:llm default
# WORKER_CPU_QUEUES=whisper:gpu whisper:io whisper:cpu whisper:llm default
# WORKER_ROCM_QUEUES=whisper:gpu whisper:io whisper:cpu whisper:llm default
# AMD single-GPU scaled topology: keep the rocm worker on GPU stages only, run a
# separate CPU worker for io/cpu, and a dedicated worker for the slow optional
# LLM correction so it never blocks the io/cpu finalisation path. Do NOT scale
# worker-rocm past 1 on one card (VRAM/compute contention).
#   WORKER_ROCM_QUEUES="whisper:gpu default"
#   WORKER_IO_QUEUES="whisper:io whisper:cpu default"
#   WORKER_LLM_QUEUES="whisper:llm default"
#   docker compose --profile rocm --profile io --profile llm-worker up -d --scale worker-io=2
# WORKER_MAX_IDLE_TIME: seconds a GPU worker (cuda/rocm SimpleWorker) stays alive
# with no job before exiting so its restart policy respawns a fresh process,
# freeing the resident GPU context + RSS. Defaulted to 300 for worker-gpu/
# worker-rocm; 0 disables (always-resident). Lower = release sooner / reload on
# next job; higher = stay warm. CPU/io/llm workers fork per job and ignore it.
# WORKER_MAX_IDLE_TIME=300

# Language
LANGUAGE=zh

# HuggingFace (required for speaker diarization)
# Get your token at https://huggingface.co/settings/tokens
# You must also accept the model agreements at:
# https://huggingface.co/pyannote/speaker-diarization-3.1
# https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=

# Queue / job timeouts (seconds)
# All have sensible defaults matching compose.yml; uncomment to override.
# Invariants are enforced at startup — the service will fail to start if:
#   0 < JOB_TIMEOUT_FLOOR <= JOB_TIMEOUT_DEFAULT <= JOB_TIMEOUT_MAX
#   REDIS_PROCESSING_EXPIRY >= JOB_TIMEOUT_MAX + STALE_JOB_BUFFER
# When raising JOB_TIMEOUT_MAX, remember to raise REDIS_PROCESSING_EXPIRY
# so Redis progress keys outlive the longest possible job.
# JOB_TIMEOUT_DEFAULT=7200          # fallback when audio duration is unknown
# JOB_TIMEOUT_FLOOR=1800            # lower bound for short audio
# JOB_TIMEOUT_AUDIO_MULTIPLIER=3.0  # dynamic = duration * multiplier, then clamped
# JOB_TIMEOUT_MAX=28800             # absolute upper cap (8h)
# STALE_JOB_BUFFER=1800             # extra margin for stale job recovery
# REDIS_PROCESSING_EXPIRY=30600     # MUST be >= JOB_TIMEOUT_MAX + STALE_JOB_BUFFER
# DIARIZE_HEARTBEAT_INTERVAL=30     # diarize progress refresh interval (0 disables)

# Optional LLM text correction (Ollama)
# Leave OLLAMA_BASE_URL unset / empty to disable the feature entirely —
# even jobs that tick the checkbox in the upload form will be silently
# skipped. The URL must NOT include the /api suffix (just the host+port);
# trailing "/api" and trailing slashes are stripped defensively, so both
# http://ollama:11434 and http://ollama:11434/api resolve to the same base,
# but any other path component is kept as-is for proxy setups.
# Malformed URLs (wrong scheme, bad port, missing host) fail at service
# startup with a clear ValidationError — this is intentional so typos
# surface immediately instead of silently disabling every opted-in job.
# Two enablement paths:
#   1. Bundled Ollama (llm profile):
#        OLLAMA_BASE_URL=http://ollama:11434
#        docker compose --profile gpu --profile llm up -d
#      The ollama-pull sidecar will fetch OLLAMA_MODEL on first startup.
#   2. External Ollama server (no llm profile needed):
#        OLLAMA_BASE_URL=http://192.168.1.20:11434
#      You're responsible for having the model pulled on that server.
# OLLAMA_BASE_URL=
# gemma4:e4b (~9.6 GB) wants a 10 GB+ GPU; on 8 GB / shared GPUs use
# gemma4:e2b (~7.2 GB) or an external Ollama server.
# OLLAMA_MODEL=gemma4:e4b
# OLLAMA_KEEP_ALIVE=30m
# OLLAMA_REQUEST_TIMEOUT=120
# LLM_CHUNK_SIZE=8
# LLM_CHUNK_CONTEXT=2
# LLM_TEMPERATURE=0.1
# Let a thinking-capable model emit chain-of-thought before its answer. Default
# false: for JSON transcript correction, thinking is markedly slower and (on
# gemma-class models) degrades the output. Set true only if a reasoning model
# is shown to help.
# OLLAMA_THINK=false

# GPU pinning (multi-GPU hosts).
# WORKER_GPU_DEVICE_ID pins the Whisper worker whenever the gpu profile is
# active (not just llm). Defaults to GPU 0. Multi-GPU hosts that previously
# relied on NVIDIA runtime auto-selection must set this explicitly to
# restore their intended placement.
# OLLAMA_GPU_DEVICE_ID only applies when the llm profile is active; it
# pins the bundled Ollama container to a specific GPU so it and the worker
# don't evict each other's models on a 2-GPU host.
# WORKER_GPU_DEVICE_ID=0
# OLLAMA_GPU_DEVICE_ID=1

# Docker image version (default: latest)
# WHISPER_UI_VERSION=latest

# Optional: custom PyPI mirror for faster builds
# PIP_INDEX_URL=

# Optional upload retention. 0 = disabled (legacy behaviour). >0 = hourly
# reclaim of COMPLETED job upload dirs older than that many days.
UPLOAD_RETENTION_DAYS=0

# -- Authentication --
# Signing key for session cookies. Generate once and keep it stable across
# restarts; rotating it invalidates every logged-in user. Leave empty for
# local development — the app falls back to a per-process random secret
# and logs a WARNING on startup.
#   SESSION_SECRET=$(openssl rand -hex 32)
SESSION_SECRET=

# When true, session cookies are only sent over HTTPS (adds the Secure
# flag). Default false so the bundled compose profiles work over plain
# HTTP. Set this to true for ANY production deployment: behind a
# TLS-terminating reverse proxy the cookie is otherwise sent in clear text
# on the proxy<->client hop.
SESSION_HTTPS_ONLY=false

# Allow open self-service registration after the first admin exists. The
# initial bootstrap admin is always creatable. Set false to close /register
# so only an admin can provision accounts (recommended for shared/public
# deployments). Default true preserves the original open-signup behaviour.
ALLOW_REGISTRATION=true

# Login rate-limit. Two independent counters guard the login endpoint:
#   - per-username: max MAX_LOGIN_ATTEMPTS failures within
#     LOGIN_LOCKOUT_SECONDS before that account is locked.
#   - per-IP:       max MAX_LOGIN_ATTEMPTS_PER_IP failures within the
#                   same window before that source IP is locked.
# Each counter has its own threshold; tripping either one rejects the
# next attempt with a generic "too many attempts" message. The per-user
# counter clears on successful login; the per-IP counter clears only on
# window expiry (so an attacker who learns one credential cannot
# launder their IP through that account to keep probing others).
# Admins can force-clear with `redis-cli DEL auth:rl:user:<name>` or
# `redis-cli DEL auth:rl:ip:<address>`.
# Defaults match safe values for a small office: 5 failures per user,
# 20 per IP, in a 15-minute window. Larger NATs sharing one egress IP
# should either raise MAX_LOGIN_ATTEMPTS_PER_IP or enable
# TRUST_PROXY_HEADERS (see below) so each real client is bucketed by
# its own address.
# MAX_LOGIN_ATTEMPTS=5
# MAX_LOGIN_ATTEMPTS_PER_IP=20
# LOGIN_LOCKOUT_SECONDS=900

# Trust X-Forwarded-For (for rate-limit client IP) and X-Forwarded-Host
# (for CSRF host comparison). ONLY enable when a controlled reverse
# proxy is in front of the app AND that proxy strips / overrides these
# headers — otherwise hostile clients can spoof both to evade the rate
# limit and CSRF check. nginx example: `proxy_set_header X-Forwarded-For
# $remote_addr;` (overrides any client-supplied value).
TRUST_PROXY_HEADERS=false

# -- Logging --
# Verbosity of the dictConfig applied by whisper_ui.core.logging_setup at
# frontend startup and at the start of the worker process. One of DEBUG,
# INFO (default), WARNING, ERROR, CRITICAL; invalid values silently fall
# back to INFO so a misconfigured .env never blocks startup. Lift to
# DEBUG when investigating a specific request (rate-limit attempt-by-
# attempt, every stage start, etc.) and drop back to INFO once done —
# DEBUG is too noisy for steady-state operation.
# LOG_LEVEL=INFO
# Emit one JSON object per log line (ts, level, logger, request_id, user_id,
# message, plus structured fields — worker stage logs carry stage/job_id/
# elapsed_ms) instead of the human-readable text format. Truthy values:
# 1/true/yes/on. Default false. Set true in production for log aggregation
# (Loki) and `jq` filtering. The text default stays easiest to read by eye.
# LOG_JSON=false

# -- Monitoring (optional) --
# `docker compose --profile monitoring up -d` adds Prometheus + a Redis
# exporter (uses REDIS_PASSWORD) + an AMD GPU exporter that scrape the
# frontend /metrics endpoint and the box. No new required keys: VIDEO_GID /
# RENDER_GID (set above for the ROCm worker) are reused by the GPU exporter.
# Prometheus is bound to 127.0.0.1:9090 and /metrics is unauthenticated —
# keep both internal / behind an authenticated proxy.
