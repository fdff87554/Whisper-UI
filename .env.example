# Redis
REDIS_URL=redis://redis:6379/0
# Optional: set a password to enable Redis authentication.
# When set, compose.yml will pass --requirepass to the Redis server
# and include the password in REDIS_URL for all services.
# REDIS_PASSWORD=

# Storage (paths inside container)
DATABASE_PATH=/app/data/db/whisper_ui.db
UPLOAD_DIR=/app/data/uploads
OUTPUT_DIR=/app/data/outputs

# Whisper
# WHISPER_MODEL: default model shown in UI dropdown.
# GPU deployment: large-v3 (default if unset)
# CPU deployment: base (recommended, set explicitly)
# WHISPER_MODEL=large-v3
COMPUTE_TYPE=int8_float16
DEVICE=cuda
# BATCH_SIZE: use 4 as default, reduce to 2 for 8GB VRAM GPUs, increase to 8+ for 16GB+ VRAM
BATCH_SIZE=4

# Language
LANGUAGE=zh

# HuggingFace (required for speaker diarization)
# Get your token at https://huggingface.co/settings/tokens
# You must also accept the model agreements at:
# https://huggingface.co/pyannote/speaker-diarization-3.1
# https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=

# Queue / job timeouts (seconds)
# All have sensible defaults matching compose.yml; uncomment to override.
# Invariants are enforced at startup — the service will fail to start if:
#   0 < JOB_TIMEOUT_FLOOR <= JOB_TIMEOUT_DEFAULT <= JOB_TIMEOUT_MAX
#   REDIS_PROCESSING_EXPIRY >= JOB_TIMEOUT_MAX + STALE_JOB_BUFFER
# When raising JOB_TIMEOUT_MAX, remember to raise REDIS_PROCESSING_EXPIRY
# so Redis progress keys outlive the longest possible job.
# JOB_TIMEOUT_DEFAULT=7200          # fallback when audio duration is unknown
# JOB_TIMEOUT_FLOOR=1800            # lower bound for short audio
# JOB_TIMEOUT_AUDIO_MULTIPLIER=3.0  # dynamic = duration * multiplier, then clamped
# JOB_TIMEOUT_MAX=28800             # absolute upper cap (8h)
# STALE_JOB_BUFFER=1800             # extra margin for stale job recovery
# REDIS_PROCESSING_EXPIRY=30600     # MUST be >= JOB_TIMEOUT_MAX + STALE_JOB_BUFFER
# DIARIZE_HEARTBEAT_INTERVAL=30     # diarize progress refresh interval (0 disables)

# Optional LLM text correction (Ollama)
# Leave OLLAMA_BASE_URL unset / empty to disable the feature entirely —
# even jobs that tick the checkbox in the upload form will be silently
# skipped. The URL must NOT include the /api suffix (just the host+port);
# trailing "/api" and trailing slashes are stripped defensively, so both
# http://ollama:11434 and http://ollama:11434/api resolve to the same base,
# but any other path component is kept as-is for proxy setups.
# Malformed URLs (wrong scheme, bad port, missing host) fail at service
# startup with a clear ValidationError — this is intentional so typos
# surface immediately instead of silently disabling every opted-in job.
# Two enablement paths:
#   1. Bundled Ollama (llm profile):
#        OLLAMA_BASE_URL=http://ollama:11434
#        docker compose --profile gpu --profile llm up -d
#      The ollama-pull sidecar will fetch OLLAMA_MODEL on first startup.
#   2. External Ollama server (no llm profile needed):
#        OLLAMA_BASE_URL=http://192.168.1.20:11434
#      You're responsible for having the model pulled on that server.
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=gemma4:e2b
# OLLAMA_KEEP_ALIVE=30m
# OLLAMA_REQUEST_TIMEOUT=120
# LLM_CHUNK_SIZE=8
# LLM_CHUNK_CONTEXT=2
# LLM_TEMPERATURE=0.1

# GPU pinning (multi-GPU hosts).
# WORKER_GPU_DEVICE_ID pins the Whisper worker whenever the gpu profile is
# active (not just llm). Defaults to GPU 0. Multi-GPU hosts that previously
# relied on NVIDIA runtime auto-selection must set this explicitly to
# restore their intended placement.
# OLLAMA_GPU_DEVICE_ID only applies when the llm profile is active; it
# pins the bundled Ollama container to a specific GPU so it and the worker
# don't evict each other's models on a 2-GPU host.
# WORKER_GPU_DEVICE_ID=0
# OLLAMA_GPU_DEVICE_ID=1

# Docker image version (default: latest)
# WHISPER_UI_VERSION=latest

# Optional: custom PyPI mirror for faster builds
# PIP_INDEX_URL=
