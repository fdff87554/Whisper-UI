FROM python:3.13-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg nodejs && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

ARG PIP_INDEX_URL=
ENV PIP_INDEX_URL=${PIP_INDEX_URL}

# Dependency layer: only project metadata plus a stub package, so editing
# src/ does not invalidate the expensive ML-dependency install below.
COPY pyproject.toml ./
RUN mkdir -p src/whisper_ui && touch src/whisper_ui/__init__.py

# Install CPU-only PyTorch first, then whisperx without deps to avoid
# pulling in CUDA torch, then remaining worker dependencies. The worker-llm
# extra adds httpx for the optional Ollama-backed correction stage; the
# stage is still gated by OLLAMA_BASE_URL at runtime.
RUN pip install --no-cache-dir torch torchaudio --index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir --no-deps "whisperx>=3.8,<3.9" && \
    pip install --no-cache-dir ".[worker,worker-llm]"

# Project layer: cheap to rebuild on every code change. --force-reinstall
# replaces the stub install of whisper-ui itself; --no-deps keeps it from
# touching the dependency layer.
COPY src/ ./src/
COPY docker/entrypoint-worker.sh ./entrypoint-worker.sh
RUN chmod +x ./entrypoint-worker.sh && \
    pip install --no-cache-dir --no-deps --force-reinstall .

RUN useradd --uid 1000 --create-home appuser 2>/dev/null || true \
    && mkdir -p /app/data/db /app/data/uploads /app/data/outputs /cache/huggingface \
    && chown -R 1000 /app/data /cache/huggingface
USER 1000

ENV HF_HOME=/cache/huggingface
ENV PYTHONUNBUFFERED=1

HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python -c "from redis import Redis; import os; r=Redis.from_url(os.environ.get('REDIS_URL','redis://redis:6379/0')); r.ping()" || exit 1

ENTRYPOINT ["./entrypoint-worker.sh"]
