FROM pytorch/pytorch:2.10.0-cuda12.8-cudnn9-runtime

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg curl unzip ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# yt-dlp (worker extra) needs a JS runtime to solve YouTube's nsig challenge.
# Deno is yt-dlp's default/preferred runtime: it is auto-detected from PATH
# when version >= 2.3.0, so no ydl_opts change is needed (apt nodejs was both
# too old and disabled-by-default in yt-dlp, hence removed). Pinned for
# reproducibility; the checksum gate guards the download and `deno --version`
# fails the build rather than shipping a worker that cannot fetch YouTube.
ARG DENO_VERSION=2.8.3
RUN curl -fsSL -o /tmp/deno.zip \
        "https://github.com/denoland/deno/releases/download/v${DENO_VERSION}/deno-x86_64-unknown-linux-gnu.zip" && \
    curl -fsSL -o /tmp/deno.zip.sha256sum \
        "https://github.com/denoland/deno/releases/download/v${DENO_VERSION}/deno-x86_64-unknown-linux-gnu.zip.sha256sum" && \
    echo "$(cut -d' ' -f1 /tmp/deno.zip.sha256sum)  /tmp/deno.zip" | sha256sum -c - && \
    unzip /tmp/deno.zip -d /usr/local/bin && \
    rm /tmp/deno.zip /tmp/deno.zip.sha256sum && \
    chmod +x /usr/local/bin/deno && \
    deno --version

WORKDIR /app

ARG PIP_INDEX_URL=
# Deliberately NOT re-exported as ENV: an ARG is already visible to RUN as
# an env var during build, so pip still honours it, but it does not persist
# into the final image config where a credentialed private index URL could
# leak via `docker inspect` / `docker history`.

# Dependency layer: only project metadata plus a stub package, so editing
# src/ does not invalidate the expensive ML-dependency install below.
COPY --from=ghcr.io/astral-sh/uv:0.11 /uv /usr/local/bin/uv
COPY pyproject.toml uv.lock ./
RUN mkdir -p src/whisper_ui && touch src/whisper_ui/__init__.py

# torch/torchaudio are pre-installed by the base image (2.10.0+cu128).
# Install whisperx without deps first to avoid its torch~=2.8.0 constraint
# triggering a downgrade; torch 2.10.0 is backward-compatible.
# Then install the remaining worker dependencies pinned to uv.lock via an
# exported constraints file, so the shipped image runs the same versions CI
# tested. The torch family is excluded from the constraints: its versions
# are owned by the base image here, not by the lock. The worker-llm extra
# adds httpx for the optional Ollama-backed correction stage; the stage is
# still gated by OLLAMA_BASE_URL at runtime.
RUN uv export --frozen --no-emit-project --no-hashes \
        --no-emit-package torch --no-emit-package torchaudio --no-emit-package triton \
        --extra worker --extra worker-llm -o /tmp/constraints.txt && \
    pip install --no-cache-dir --break-system-packages --no-deps "whisperx==3.8.6" && \
    pip install --no-cache-dir --break-system-packages -c /tmp/constraints.txt ".[worker,worker-llm]" && \
    python -c "import whisperx"

# Project layer: cheap to rebuild on every code change. --force-reinstall
# replaces the stub install of whisper-ui itself; --no-deps keeps it from
# touching the dependency layer.
COPY src/ ./src/
COPY docker/entrypoint-worker.sh ./entrypoint-worker.sh
RUN chmod +x ./entrypoint-worker.sh && \
    pip install --no-cache-dir --break-system-packages --no-deps --force-reinstall .

RUN useradd --uid 1000 --create-home appuser 2>/dev/null || true \
    && mkdir -p /app/data/db /app/data/uploads /app/data/outputs /cache/huggingface \
    && chown -R 1000 /app/data /cache/huggingface
USER 1000

ENV HF_HOME=/cache/huggingface
ENV PYTHONUNBUFFERED=1

HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python -c "from redis import Redis; import os; r=Redis.from_url(os.environ.get('REDIS_URL','redis://redis:6379/0')); r.ping()" || exit 1

ENTRYPOINT ["./entrypoint-worker.sh"]
